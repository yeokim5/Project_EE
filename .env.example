# Copy to .env for live extraction mode.
# Recorded/offline mode must work without any API key.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low

# Optional for the Phase 10 web UI when the Python API is deployed separately.
# Local example: PYTHON_API_BASE_URL=http://127.0.0.1:8000
PYTHON_API_BASE_URL=
